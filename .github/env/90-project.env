# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-chaincfg
# Load Order: 90 (loaded after all default/tool configs, overrides everything except 99-local.env)
#
# This file contains configuration values that are specific to this project and
# override the defaults defined in earlier env files (00-core, 10-*, 20-*).
#
# Override in: 99-local.env (local development only, git-ignored)
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 🪄 MAGE-X CONFIGURATION
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER CONFIGURATION
# ================================================================================================

# Use Codecov as the coverage provider (overrides internal default from 10-coverage.env)
GO_COVERAGE_PROVIDER=codecov

# Require Codecov token for uploads
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS (aligned with codecov.yml ignore paths)
# ================================================================================================

# Coverage path exclusions — matches codecov.yml ignore list plus standard Go exclusions
GO_COVERAGE_EXCLUDE_PATHS=test/,vendor/,testdata/,examples/,example/,.github/,.mage-cache/,.vscode/,bin/,mocks/,testing/,plans/,docs/
